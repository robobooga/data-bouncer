{
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm uninstall:*)",
      "Bash(du -sh node_modules/*)",
      "Bash(find src/ -type f -exec wc -c {} +)",
      "Bash(find vendor/ -type f -exec wc -c {} +)",
      "Bash(npm ls:*)",
      "Bash(git count-objects:*)"
    ]
  }
}
