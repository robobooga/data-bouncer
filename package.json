{
  "name": "bouncer-extension",
  "version": "0.1.0",
  "type": "module",
  "description": "Security-first Chrome Extension for scraping web content with PII redaction",
  "scripts": {
    "dev": "echo 'Development mode - load unpacked extension from Chrome'",
    "build": "node scripts/build.js",
    "icons": "node scripts/generate-icons.js",
    "test": "jest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{js,css,html}\""
  },
  "keywords": [
    "chrome-extension",
    "pii-redaction",
    "web-scraper",
    "markdown",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.2.5",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "turndown": "^7.1.3"
  }
}
